@page "/product/create"
@model CatalogService.Pages.CreateProduct
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Create Product</title>
</head>
<body>
<div class="container mt-4">
    <h1>Create Product</h1>
    <hr />

    <form method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label>Name</label>
            <input asp-for="Product.Name" class="form-control"/>
        </div>
        <div class="mb-3">
            <label>Brand</label>
            <input asp-for="Product.Brand" class="form-control"/>
        </div>
        <div class="mb-3">
            <label>Model</label>
            <input asp-for="Product.Model" class="form-control"/>
        </div>
        <div class="mb-3">
            <label>Description</label>
            <input asp-for="Product.Description" class="form-control"/>
        </div>
        <div class="mb-3">
            <label>SKU</label>
            <input asp-for="Product.Sku" class="form-control"/>
        </div>
        <div class="mb-3">
            <label>Price</label>
            <input asp-for="Product.Price" class="form-control"/>
        </div>
        <div class="mb-3">
            <label>Currency</label>
            <input asp-for="Product.Currency" class="form-control"/>
        </div>

        <button type="submit" class="btn btn-primary">Create</button>
        <a href="/product/list" class="btn btn-secondary">Cancel</a>
    </form>
</div>
</body>
</html>